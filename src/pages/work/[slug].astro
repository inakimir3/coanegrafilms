---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Headers/HeaderWork.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';

export async function getStaticPaths() {
  return projects.map((project) => {
    const slug = project.link.split('/').pop();
    return {
      params: { slug },
      props: { project },
    };
  });
}

const { project } = Astro.props;
const gallery = project.gallery || [];

const displayImages = gallery; 
const COLS = 3; 
const GAP_X = 50; // vw
const GAP_Y = 60; // vh
---

<Layout title={project.title + " - Coanega Films"}>
  <Header />
  
  <section class="c-detail">
    <video 
      src={project.video} 
      playsinline 
      autoplay
      muted
      loop
      class="c-detail__video"
    ></video>
    <article class="c-detail__content">
      <h1 class="c-detail__title">{project.title}</h1>
      <p class="c-detail__description">{project.description}</p>
      <button class="c-detail__button">Play video</button>
    </article>
  </section>
  
  <section class="c-explorer" id="explorer-container">
    <div class="c-explorer__canvas" id="canvas">
      {displayImages.map((src, i) => {
        const col = i % COLS;
        const row = Math.floor(i / COLS);
        const offsetRow = (col % 2 === 0) ? 0 : 30; 

        return (
          <div 
            class="c-explorer__item js-explorer-item cursor-pointer group" 
            style={`left: ${col * GAP_X + 90}vw; top: ${row * GAP_Y + offsetRow + 100}vh;`}
            data-src={src}
          >
            <img src={src} alt={project.title} draggable="false"/>
          </div>
        );
      })}
    </div>
  </section>

  <div id="image-modal" class="c-modal" aria-hidden="true">
    <div class="c-modal__overlay js-close-modal"></div>
    <button class="c-modal__close js-close-modal" aria-label="Tancar">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="c-modal__content">
      <img id="modal-img" src="" alt="" class="c-modal__img" />
    </div>
  </div>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";

  gsap.registerPlugin(Draggable);

  function initAdvancedCanvas() {
    const canvas = document.getElementById("canvas");
    const container = document.getElementById("explorer-container");
    const modal = document.getElementById("image-modal");
    const modalImg = document.getElementById("modal-img") as HTMLImageElement;
    const items = document.querySelectorAll(".js-explorer-item");
    const closeButtons = document.querySelectorAll(".js-close-modal");

    if (!canvas || !container || !modal) return;

    // Draggable Logic
    const startX = -(canvas.offsetWidth / 2 - window.innerWidth / 2);
    const startY = -(canvas.offsetHeight / 2 - window.innerHeight / 2);
    gsap.set(canvas, { x: startX, y: startY });

    Draggable.create(canvas, {
      type: "x,y",
      bounds: container,
      inertia: true,
      edgeResistance: 0.6,
      onThrowComplete: () => {
        gsap.to(canvas, { filter: "blur(0px)", duration: 0.6, ease: "power2.out" });
      }
    });

    items.forEach(item => {
      item.addEventListener("click", () => {
        const src = item.getAttribute("data-src");
        if (src) {
          modalImg.src = src;
          modal.classList.add("is-active");
          document.body.style.overflow = "hidden";
          
          gsap.fromTo(modal, { opacity: 0 }, { opacity: 1, duration: 0.4 });
          gsap.fromTo(modalImg, { scale: 0.9 }, { scale: 1, duration: 0.5, ease: "back.out(1.5)" });
        }
      });
    });

    const closeModal = () => {
      gsap.to(modal, { 
        opacity: 0, 
        duration: 0.3, 
        onComplete: () => {
          modal.classList.remove("is-active");
          document.body.style.overflow = "";
        } 
      });
    };

    closeButtons.forEach(b => b.addEventListener("click", closeModal));
    window.addEventListener("keydown", (e) => { if(e.key === "Escape") closeModal(); });
  }

  document.addEventListener("astro:page-load", initAdvancedCanvas);
</script>

