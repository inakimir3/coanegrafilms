
<section class="c-slider">
    <a class="c-slider__link" href="#">
        <div class="c-slider__videos">

            <video src="/videos/test1.mp4" poster="/posters/poster-01.png" autoplay muted loop playsinline class="w-full h-full object-cover"></video>
        </div>

        <div class="c-slider__title">
            <h2>Zalando Social Media</h2>
        </div>

        <div class="c-slider__indicator">
            <div class="c-slider__indices"></div>
            <div class="c-slider__progress-bar">
                <div class="c-slider__progress"></div>
            </div>
        </div>
    </a>
</section>


<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';
    import Lenis from 'lenis';

    gsap.registerPlugin(ScrollTrigger, SplitText);

    function initSlider() {
        const sliderElement = document.querySelector('.c-slider');
        if (!sliderElement) return;

        const lenis = new Lenis();
        const onRaf = (time) => lenis.raf(time * 1000);
        
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add(onRaf);
        gsap.ticker.lagSmoothing(0);

        const slides = [
            { title: "Zalando Social Media", video: "/videos/test1.mp4", link: "#", poster: "/posters/poster-01.png" },
            { title: "Vi de la Terra", video: "/videos/test2.mp4", link: "#", poster: "/posters/poster-02.png" },
            { title: "Namibia", video: "/videos/test1.mp4", link: "#", poster: "/posters/poster-03.png" },
            { title: "Iceland", video: "/videos/test2.mp4", link: "#", poster: "/posters/poster-01.png" },
            { title: "Jordania", video: "/videos/test1.mp4", link: "#", poster: "/posters/poster-02.png" },
        ];

        const pinDistance = window.innerHeight * slides.length;
        const progressBar = document.querySelector('.c-slider__progress');
        const sliderVideos = document.querySelector('.c-slider__videos');
        const sliderTitle = document.querySelector('.c-slider__title');
        const sliderIndices = document.querySelector('.c-slider__indices');
        const sliderLink = document.querySelector('.c-slider__link');

        let activeSlide = 0;
        let currentSplit = null;

        function createIndices() {
            sliderIndices.innerHTML = "";
            slides.forEach((_, index) => {
                const indexNum = (index + 1).toString().padStart(2, '0');
                const indicatorElement = document.createElement('p');
                indicatorElement.innerHTML = `<span class="index" style="opacity: ${index === 0 ? 1 : 0.35}">${indexNum}</span>`;
                sliderIndices.appendChild(indicatorElement);
            });
        }

        function animatedNewTitle(index) {
            if (currentSplit) currentSplit.revert();
            sliderTitle.innerHTML = `<h2>${slides[index].title}</h2>`;
            
            currentSplit = new SplitText(sliderTitle.querySelector('h2'), {
                type: "lines",
                linesClass: "line-parent"
            });

            currentSplit.lines.forEach(line => {
                const wrapper = document.createElement('div');
                wrapper.style.overflow = 'hidden';
                line.parentNode.insertBefore(wrapper, line);
                wrapper.appendChild(line);
            });

            gsap.from(currentSplit.lines, {
                yPercent: 100,
                duration: 0.8,
                stagger: 0.1,
                ease: "expo.out"
            });
        }

        function animatedNewSlide(index) {
            const newVideo = document.createElement('video');
            Object.assign(newVideo, {
                src: slides[index].video,
                poster: slides[index].poster,
                autoplay: true,
                muted: true,
                loop: true,
                preload: "metadata",
                playsInline: true,
                className: "w-full h-full object-cover absolute inset-0"
            });

            sliderLink.href = slides[index].link;
            gsap.set(newVideo, { clipPath: "inset(100% 0% 0% 0%)", scale: 1.1 });
            sliderVideos.appendChild(newVideo);

            const videos = sliderVideos.querySelectorAll("video");
            const previousVideo = videos[videos.length - 2];

            const tl = gsap.timeline({ defaults: { ease: "expo.inOut", duration: 1.2 } });

            if (previousVideo) {
                tl.to(previousVideo, { scale: 0.9, opacity: 0, duration: 1 }, 0);
            }

            tl.to(newVideo, { clipPath: "inset(0% 0% 0% 0%)", scale: 1 }, 0);

            if (videos.length > 2) {
                setTimeout(() => videos[0].remove(), 1300);
            }

            animatedNewTitle(index);
            animatedIndicators(index);
        }

        function animatedIndicators(index) {
            const indicators = sliderIndices.querySelectorAll(".index");
            indicators.forEach((el, i) => {
                gsap.to(el, { opacity: i === index ? 1 : 0.35, duration: 0.3 });
            });
        }

        createIndices();
        
        const mainST = ScrollTrigger.create({
            trigger: ".c-slider",
            start: "top top",
            end: `+=${pinDistance}`,
            pin: true,
            scrub: true,
            onUpdate: (self) => {
                gsap.set(progressBar, { scaleY: self.progress, transformOrigin: "top" });
                const currentSlide = Math.floor(self.progress * (slides.length - 0.01));
                if (activeSlide !== currentSlide) {
                    activeSlide = currentSlide;
                    animatedNewSlide(activeSlide);
                }
            },
            onLeave: () => {
                gsap.to([sliderTitle, sliderIndices], { y: -20, opacity: 0, autoAlpha: 0 });
            },
            onEnterBack: () => {
                gsap.to([sliderTitle, sliderIndices], { y: 0, opacity: 1, autoAlpha: 1 });
            }
        });

        document.addEventListener("astro:before-preparation", () => {
            lenis.destroy();
            mainST.kill();
            gsap.ticker.remove(onRaf);
        }, { once: true });
    }

    document.addEventListener("astro:page-load", initSlider);
</script>