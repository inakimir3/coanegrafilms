---
const {title, href, imageSrc, videoSrc} = Astro.props;
---

<a href={href} class="recentCard group col-span-1 flex flex-col gap-2">
    <div class="relative video-container">
        <div class="absolute top-0 left-0 w-full h-full bg-black opacity-20"></div>
        <img src={imageSrc} class="w-full h-auto object-cover aspect-340/480">
        <video 
            src={videoSrc} 
            class="absolute top-0 left-0 w-full h-full object-cover aspect-343/480 opacity-0 transition-opacity duration-300" 
            muted 
            loop
            playsinline
        ></video>
    </div>
    <h4 class="tracking-[-5%] flex items-center gap-0 text-[24px] group-hover:ml-2 -ml-1 transition-all duration-300 group-hover:gap-4">
        <img src="/icons/red-circle.svg" class="w-4 opacity-0 group-hover:opacity-100 group-hover:rotate-180 transition-all duration-300">
        <span>{title}</span>
    </h4>
</a>

<script>
  const containers = document.querySelectorAll('.video-container');

  containers.forEach(container => {
    const video = container.querySelector('video');

    container.addEventListener('mouseenter', () => {
      video.play();
      video.style.opacity = 1;
    });

    container.addEventListener('mouseleave', () => {
      video.pause();
      video.style.opacity = 0;
    });
  });
</script>