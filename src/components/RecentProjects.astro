---
import Card from './Card.astro';
---

<section class="pb-60 px-5 lg:px-10 py-5 grid grid-cols-10 gap-x-5">
    
    <article class="col-start-1 lg:col-start-2 col-span-10 lg:col-span-8 flex items-center justify-between">
        <h2 class="text-[40px] lg:text-[64px] tracking-[-5%]">
            Recent projects
        </h2>

        <a href="#" class="tracking-[-5%] group flex items-center gap-2 text-[16px] lg:text-[18px] text-[#C2C2C2] transition-all duration-300 hover:gap-4">
            <img src="/icons/red-circle.svg" class="group-hover:rotate-180 transition-all duration-300">
            <span>See all projects</span>
        </a>
    </article>

    <article class="mt-16 lg:hidden col-span-10">
        <div class="swiper">
            <div class="swiper-wrapper">

                <div class="swiper-slide">
                    <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
                </div>

                <div class="swiper-slide">
                    <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
                </div>

                <div class="swiper-slide">
                    <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
                </div>

            </div>
        </div>
    </article>

    <article class="hidden lg:grid mt-24 col-start-2 col-span-8 grid-cols-3 gap-5">
        <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
        <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
        <Card title="Vi de la Terra" href="#" imageSrc="/images/cover-videlaterra.png" videoSrc="/videos/video-videlaterra.mp4" />
    </article>

</section>

<script>
    import Swiper from 'swiper/bundle';
    import 'swiper/css/bundle';

    const swiper = new Swiper('.swiper', {
        spaceBetween: 16,
        slidesPerView: 1.2, // 👈 una completa + trozo de la siguiente
    });
</script>