<section id="aboutSection" class="px-10 py-60 grid grid-cols-10 gap-5">
  <h2 class="about-title text-[48px] col-span-8 col-start-2 tracking-[-5%] leading-12">
    Coanegra Films is a creative studio dedicated to world-class visual arts. As your creative partners, we transform concepts into powerful visual stories.
  </h2>

  <a href="#" class="about-cta tracking-[-5%] group col-start-2 col-span-2 flex items-center gap-2 text-[18px] text-[#C2C2C2]">
    <img src="/icons/red-circle.svg" class="group-hover:rotate-180 transition-all duration-300">
    <span>About us</span>
  </a>
</section>


<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

const tlAbout = gsap.timeline({
  scrollTrigger: {
    trigger: "#aboutSection",
    start: "top 80%",
    toggleActions: "play none none reverse",
  }
});

tlAbout.from(".about-title", {
  y: 160,
  opacity: 0,
  duration: 1.7,
  ease: "power3.out",
})
.from(".about-cta", {
  y: 130,
  opacity: 0,
  duration: 0.6,
  ease: "power2.out"
}, "-=0.6");
</script>